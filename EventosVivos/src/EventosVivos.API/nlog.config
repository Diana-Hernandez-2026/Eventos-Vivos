<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Warn"
      internalLogFile="${basedir}/logs/nlog-internal.txt">

  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
  </extensions>

  <targets>
    <!-- Stdout for containers (Docker/Kubernetes captures this) -->
    <target xsi:type="Console" name="console"
            layout="${longdate}|${level:uppercase=true}|${logger:shortName=true}|${message} ${exception:format=message}" />

    <!-- File target uses a path relative to the app base dir so it works on both Windows and Linux -->
    <target xsi:type="File" name="file"
            fileName="${basedir}/logs/eventosvivos-${shortdate}.log"
            layout="${longdate}|${event-properties:item=EventId_Id:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}|url: ${aspnet-request-url}|action: ${aspnet-mvc-action}" />
  </targets>

  <rules>
    <!-- Suppress noisy framework loggers -->
    <logger name="Microsoft.*"    maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />

    <!-- Application logs go to both console and file -->
    <logger name="EventosVivos.*" minlevel="Trace" writeTo="console,file" />

    <!-- All other loggers: console only -->
    <logger name="*" minlevel="Info" writeTo="console" />
  </rules>
</nlog>
