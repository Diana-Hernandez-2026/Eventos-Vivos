{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=eventosvivos.db"
  },
  "JwtSettings": {
    "Secret": "REPLACE_WITH_A_SECURE_SECRET_AT_LEAST_32_CHARS_LONG",
